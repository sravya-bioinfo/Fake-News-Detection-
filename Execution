"""
=============================================================
  Fake News Detection using NLP
  Industry: Media
  Tools: Python, Scikit-learn, NLTK, (optionally HuggingFace)
=============================================================

Description:
    This script builds a machine learning pipeline to classify
    news articles as REAL or FAKE using NLP techniques.

Steps:
    1. Load and preprocess text data
    2. Split into train/test sets
    3. Train a Logistic Regression model (TF-IDF based)
    4. Evaluate with accuracy, precision, recall, F1
    5. Analyze false positives and false negatives
    6. Provide a simple prediction interface

Dataset:
    Fake News Dataset from Kaggle:
    https://www.kaggle.com/c/fake-news/data
    Files needed: train.csv (columns: id, title, author, text, label)
    label: 1 = FAKE, 0 = REAL

Usage:
    python fake_news_detection.py
"""

import os
import re
import numpy as np
import pandas as pd
import nltk
import warnings

from sklearn.model_selection import train_test_split
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import (accuracy_score, precision_score,
                             recall_score, f1_score,
                             classification_report, confusion_matrix)
from sklearn.pipeline import Pipeline

warnings.filterwarnings("ignore")

# ─── NLTK Downloads ────────────────────────────────────────────────────────────
nltk.download("stopwords", quiet=True)
nltk.download("punkt", quiet=True)
from nltk.corpus import stopwords

STOP_WORDS = set(stopwords.words("english"))


# ══════════════════════════════════════════════════════════════════════════════
# STEP 1 — DATA LOADING
# ══════════════════════════════════════════════════════════════════════════════

def load_data(filepath: str) -> pd.DataFrame:
    """
    Load the Kaggle Fake News dataset CSV.

    Args:
        filepath: Path to train.csv

    Returns:
        DataFrame with columns [title, author, text, label]
    """
    print(f"\n[1/5] Loading data from: {filepath}")
    df = pd.read_csv(filepath)

    # Keep relevant columns; fill missing values
    df = df[["title", "author", "text", "label"]].copy()
    df.fillna("", inplace=True)

    # Combine title + author + text for richer signal
    df["content"] = (
        df["title"].astype(str) + " " +
        df["author"].astype(str) + " " +
        df["text"].astype(str)
    )

    print(f"    Total samples : {len(df)}")
    print(f"    REAL (0)      : {(df['label'] == 0).sum()}")
    print(f"    FAKE (1)      : {(df['label'] == 1).sum()}")
    return df


